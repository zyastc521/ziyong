[Proxy Chain]

[Proxy Group]
#手动
#--------------------------------
#策略
兜底策略 = select,香港故障转移,台湾故障转移,日本故障转移,新国故障转移,美国故障转移,全球策略,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Rocket.png
全球策略 = select,香港自动选择（低倍）,美国自动选择（低倍）,其他自动选择（低倍）,媒体节点,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/Global.png
Telegram = select,Telegram节点,img-url = https://raw.githubusercontent.com/zyastc521/ziyong/main/icon/Loon/Telegram.png
AI = select,美国节点,img-url = https://raw.githubusercontent.com/zyastc521/ziyong/main/icon/Loon/ChatGPT.png
YouTube = select,香港故障转移,台湾故障转移,日本故障转移,新国故障转移,美国故障转移,img-url = https://raw.githubusercontent.com/zyastc521/ziyong/main/icon/Loon/YouTube.png
TikTok = select,香港故障转移,台湾故障转移,日本故障转移,新国故障转移,美国故障转移,img-url = https://raw.githubusercontent.com/zyastc521/ziyong/main/icon/Loon/TikTok.png
Spotify = select,DIRECT,兜底策略,img-url = https://raw.githubusercontent.com/zyastc521/ziyong/main/icon/Loon/Spotify.png
#--------------------------------
#自动
#--------------------------------
#故障转移
香港故障转移 = fallback,香港节点,interval = 600,max-timeout = 1000,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/HK.png
台湾故障转移 = fallback,台湾节点,interval = 600,max-timeout = 1000,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/TW.png
日本故障转移 = fallback,日本节点,interval = 600,max-timeout = 1000,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/JP.png
新国故障转移 = fallback,新国节点,interval = 600,max-timeout = 1000,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SG.png
美国故障转移 = fallback,美国节点,interval = 600,max-timeout = 1000,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/US.png
#--------------------------------
#自动选择
香港自动选择（低倍） = url-test,香港低倍,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/HK.png
美国自动选择（低倍） = url-test,美国低倍,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/US.png
其他自动选择（低倍） = url-test,其他低倍,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/Global.png
#--------------------------------
#负载均衡
#--------------------------------

[Remote Filter]
Telegram节点 = NameRegex, FilterKey = "(?=.*(新|狮|獅|SG|(?i)Singapore))^((?!(筛选|Premium)).)*$"
媒体节点 = NameRegex, FilterKey = "(?=.*((?i)bage|fxt|0.1|bgp-0.3|筛选|特定))^((?!(jp|0.1筛选|0.01筛选)).)*$"
香港低倍 = NameRegex, FilterKey = "(?=.*((?i)0.1筛选))^((?!(us|美国|日本|英国|印度|荷兰)).)*$"
美国低倍 = NameRegex,一分（1T）,赔钱（1T）, FilterKey = "(?=.*((?i)0.1筛选))^((?!(香港|日本|英国|印度|荷兰)).)*$"
其他低倍 = NameRegex, FilterKey = "(?=.*((?i)下载|cf|pro))^((?!(客户端)).)*$"
高倍节点 = NameRegex,M78（200G）, FilterKey = "(?=.*((?i)x|倍))^((?!(0.6|0.3)).)*$"
家宽节点 = NameRegex, FilterKey = "家宽|高级|原生|verizon|home"
冷门节点 = NameRegex, FilterKey = "^(?!.*(Expire|Traffic|ws|emby|com|收藏|深港|原生|优惠码|高级|下载|秒连云|邀请|节点|机场|群|家宽|香港|台湾|日本|新加坡|美国|HK|US|TW|JP|SG|TG|SP|Hong|Tai|Japan|Singapore|States))"
香港节点 = NameRegex, FilterKey = "(?=.*(港|HK|(?i)Hong))^((?!(筛选|特定|Premium|香港S01|-1.0倍率|-2.5倍率|游戏)).)*$"
台湾节点 = NameRegex, FilterKey = "(?=.*(台|TW|(?i)Tai))^((?!(筛选|特定|Premium|占位)).)*$"
日本节点 = NameRegex, FilterKey = "(?=.*(日|JP|(?i)Japan))^((?!(筛选|特定|Premium|尼日利亚|-1.0倍率|-1.1倍率|-4.0倍率|-5倍率)).)*$"
新国节点 = NameRegex, FilterKey = "(?=.*(新|狮|獅|SG|(?i)Singapore))^((?!(筛选|特定|Premium|-0.1倍率)).)*$"
美国节点 = NameRegex, FilterKey = "(?=.*(美|US|(?i)States|American))^((?!(筛选|特定|pure|Premium|0.3|0.1倍|-0倍率|-1.5倍率|-0.8倍率)).)*$"

[Rule]
# 防止TG加载转圈
#IP-CIDR,95.161.76.100/31,REJECT-NO-DROP,no-resolve
# Local Rule
# Type:DOMAIN-SUFFIX,DOMAIN,DOMAIN-KEYWORD,USER-AGENT,URL-REGEX,IP-CIDR,IP-CIDR6,IP-ASN
# Strategy:DIRECT,Proxy,REJECT
# Options:no-resolve(no-resolve(only for cidr))
# IP-CIDR, 192.168.0.0/16, DIRECT
# IP-CIDR, 10.0.0.0/8, DIRECT
# IP-CIDR, 172.16.0.0/12, DIRECT
# IP-CIDR, 127.0.0.0/8, DIRECT
# 配置文件已自带远程GEOIP, cn, DIRECT规则，请勿在此添加
# 请勿修改远程CN REGION规则的排序甚至删除
# IP-CIDR,28.0.0.1/8,DIRECT
# IP-CIDR,198.18.0.1/16,DIRECT
# IP-CIDR,198.18.0.0/15,DIRECT
# IP-CIDR6,fc00::/18,DIRECT
FINAL,兜底策略

